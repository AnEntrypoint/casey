node_modules/
data/
*.log

# stray crash dumps (e.g. MSYS bash.exe.stackdump on Windows) -- never source
*.stackdump

# operator secrets -- scaffolded by `casey init`, never committed
.env

# editor / agent session state. Ignore everything under .claude EXCEPT the
# reusable project workflows, which are source and should be tracked. (git will
# not descend into an excluded dir, so we exclude .claude/* by glob -- not the
# dir itself -- then re-include the workflows path.)
.claude/*
!.claude/workflows/

# gm-plugkit runtime working state is ignored per-entry below; the shared
# memory corpus (.gm/memories/) and plan state (.gm/prd.yml, .gm/mutables.yml)
# are tracked source of record.
# >>> plugkit managed
.gm/exec-spool/
.gm/gm-fired-*
.gm/needs-gm
.gm/lastskill
.gm/turn-state.json
.gm/turn-state.json.corrupted-*
.gm/residual-check-fired
.gm/bootstrap-status.json
.gm/bootstrap-error.json
.gm/rslearn-counter.json
.gm/trajectory-drafts/
.gm/ingest-drafts/
.gm/prd-state.json
.gm/subagent-*.json
.gm/browser-profile/
.gm/browser-profile-*/
.gm/browser-state/
.gm/build-tool-ignores.md
.gm/last-prompt.txt
.gm/hooks/
.gm/no-memorize-this-turn
.gm/prd.paused.yml
.gm/rs-learn.db
.gm/rs-learn.db-shm
.gm/rs-learn.db-wal
.gm/gm.db
.gm/gm.db-shm
.gm/gm.db-wal
.gm/learning-state.md
.gm/git-block-counter.json
.gm/next-step.md
.gm/constraints.md
